default_platform(:ios)

require "shellwords"
require "fileutils"
require "cgi"
require "json"
require "pathname"

REPO_ROOT = File.expand_path("..", __dir__)
PROJECT = File.join(REPO_ROOT, "Hackers.xcodeproj")
SCHEME = "Hackers"
APP_IDENTIFIER = "com.weiranzhang.Hackers"
EXTENSION_IDENTIFIER = "com.weiranzhang.Hackers.ActionExtension"
TEAM_ID = "2KB59GPA9B"
DESTINATION = "platform=iOS Simulator,name=iPhone 17 Pro"
RELEASE_DIR = File.join(REPO_ROOT, "artifacts/release")
LOG_DIR = File.join(REPO_ROOT, "artifacts/logs")
SNAPSHOT_CACHE_DIR = File.expand_path("~/Library/Caches/tools.fastlane/screenshots")
SCREENSHOT_OUTPUT_DIR = File.join(REPO_ROOT, "artifacts/screenshots")
FRAMEIT_ASSET_DIR = File.join(REPO_ROOT, "fastlane", "frameit")

def app_store_connect_key
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_P8"),
    is_key_content_base64: false
  )
end

def project_build_setting(setting, target_name: "Hackers")
  require "xcodeproj"

  project = Xcodeproj::Project.open(PROJECT)
  target = project.targets.find { |item| item.name == target_name }
  UI.user_error!("Target not found: #{target_name}") unless target

  values = target.build_configurations.map { |config| config.build_settings[setting].to_s }.uniq
  UI.user_error!("No #{setting} found for #{target_name}") if values.empty?
  UI.user_error!("Mismatched #{setting} values for #{target_name}: #{values.join(', ')}") if values.length > 1
  values.first
end

def write_screenshot_summary(output_dir)
  screenshots = Dir[File.join(output_dir, "**", "*.png")].sort
  framed_screenshots = screenshots.select { |path| File.basename(path, ".png").end_with?("_framed") }
  screenshots = framed_screenshots unless framed_screenshots.empty?
  screens = Hash.new { |hash, key| hash[key] = [] }

  screenshots.each do |path|
    relative_path = Pathname.new(path).relative_path_from(Pathname.new(output_dir)).to_s
    path_parts = relative_path.split(File::SEPARATOR)
    appearance = path_parts.length >= 3 ? path_parts[-3] : "default"
    locale = path_parts.length >= 2 ? path_parts[-2] : File.basename(File.dirname(path))
    file_name = File.basename(path, ".png").sub(/_framed\z/, "")
    match = file_name.match(/\A(.+)-(\d{2}-.+)\z/)
    device = match ? match[1] : "Unknown Device"
    screen = match ? match[2] : file_name
    screens[screen] << {
      appearance: appearance,
      device: device,
      locale: locale,
      path: relative_path
    }
  end

  devices = screens.values.flatten.map { |item| item[:device] }.uniq.sort
  appearances = screens.values.flatten.map { |item| item[:appearance] }.uniq.sort
  html = +"<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Hackers Screenshots</title><style>"
  html << "body{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;margin:32px;background:#f7f7f4;color:#1d1d1f}h1{margin:0 0 8px}h2{margin:40px 0 16px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px}.shot{background:white;border:1px solid #ddd;border-radius:8px;padding:12px}.shot h3{font-size:14px;margin:0 0 10px;color:#555}.shot img{display:block;width:100%;height:auto;border-radius:4px;border:1px solid #eee}.appearance{text-transform:capitalize;font-weight:700}"
  html << "</style></head><body><h1>Hackers Screenshots</h1><p>#{screenshots.length} screenshots generated from #{devices.length} devices across #{appearances.length} appearances.</p>"
  screens.keys.sort.each do |screen|
    html << "<h2>#{CGI.escapeHTML(screen)}</h2><div class=\"grid\">"
    screens[screen].sort_by { |item| [item[:appearance], item[:device], item[:locale]] }.each do |item|
      escaped_path = CGI.escapeHTML(item[:path])
      label = "#{item[:appearance]} · #{item[:device]} · #{item[:locale]}"
      html << "<div class=\"shot\"><h3><span class=\"appearance\">#{CGI.escapeHTML(item[:appearance])}</span> · #{CGI.escapeHTML(item[:device])} · #{CGI.escapeHTML(item[:locale])}</h3><a href=\"#{escaped_path}\"><img src=\"#{escaped_path}\" alt=\"#{CGI.escapeHTML(label)} #{CGI.escapeHTML(screen)}\"></a></div>"
    end
    html << "</div>"
  end
  html << "</body></html>"

  File.write(File.join(output_dir, "screenshots.html"), html)
end

def prepare_frameit_metadata(output_dir)
  framefile_path = File.join(FRAMEIT_ASSET_DIR, "Framefile.json")
  framefile = JSON.parse(File.read(framefile_path))
  background_path = Pathname.new(File.join(FRAMEIT_ASSET_DIR, "background.png"))
  output_path = Pathname.new(output_dir)
  framefile["default"]["background"] = background_path.relative_path_from(output_path).to_s
  frameit_font_path = Pathname.new("/System/Library/Fonts/SFNS.ttf")
  frameit_font = frameit_font_path.relative_path_from(output_path).to_s
  ["keyword", "title"].each do |text_type|
    framefile["default"][text_type]["font"] = frameit_font
  end

  File.write(File.join(output_dir, "Framefile.json"), JSON.pretty_generate(framefile))

  locale_dir = File.join(output_dir, "en-US")
  FileUtils.mkdir_p(locale_dir)
  ["title.strings", "keyword.strings"].each do |file_name|
    FileUtils.cp(File.join(FRAMEIT_ASSET_DIR, file_name), File.join(locale_dir, file_name))
  end
end

def marketing_version
  project_build_setting("MARKETING_VERSION")
end

def source_build_number
  project_build_setting("CURRENT_PROJECT_VERSION").to_i
end

def release_tag_parts(tag)
  match = tag.to_s.match(/\Av(?<version>\d+\.\d+\.\d+)(?:\+(?<build>\d+))?\z/)
  UI.user_error!("Release tag must be vX.Y.Z or vX.Y.Z+N, got #{tag}") unless match

  {
    version: match[:version],
    build_number: match[:build]&.to_i
  }
end

def require_release_tag_build_number!(tag)
  tag_parts = release_tag_parts(tag)
  UI.user_error!("Release tag must be vX.Y.Z+N for build-tracked releases, got #{tag}") unless tag_parts[:build_number]
end

def set_build_number(build_number)
  require "xcodeproj"

  project = Xcodeproj::Project.open(PROJECT)
  ["Hackers", "HackersActionExtension"].each do |target_name|
    target = project.targets.find { |item| item.name == target_name }
    UI.user_error!("Target not found: #{target_name}") unless target

    target.build_configurations.each do |config|
      config.build_settings["CURRENT_PROJECT_VERSION"] = build_number.to_s
    end
  end
  project.save
end

def set_app_store_signing
  require "xcodeproj"

  profiles = {
    "Hackers" => "match AppStore #{APP_IDENTIFIER}",
    "HackersActionExtension" => "match AppStore #{EXTENSION_IDENTIFIER}"
  }

  project = Xcodeproj::Project.open(PROJECT)
  profiles.each do |target_name, profile_name|
    target = project.targets.find { |item| item.name == target_name }
    UI.user_error!("Target not found: #{target_name}") unless target

    target.build_configurations.each do |config|
      next unless config.name == "Release"

      config.build_settings["CODE_SIGN_STYLE"] = "Manual"
      config.build_settings["CODE_SIGN_IDENTITY"] = "Apple Distribution"
      config.build_settings["CODE_SIGN_IDENTITY[sdk=iphoneos*]"] = "Apple Distribution"
      config.build_settings["DEVELOPMENT_TEAM"] = TEAM_ID
      config.build_settings["PROVISIONING_PROFILE_SPECIFIER"] = profile_name
    end
  end
  project.save
end

def validate_release_tag!(tag)
  UI.user_error!("Release tag is required") if tag.to_s.empty?

  tag_version = release_tag_parts(tag)[:version]
  current_version = marketing_version
  return if tag_version == current_version

  UI.user_error!("Tag #{tag} does not match MARKETING_VERSION #{current_version}")
end

def validate_release_tag_build_number!(tag, build_number)
  tag_build_number = release_tag_parts(tag)[:build_number]
  return unless tag_build_number
  return if tag_build_number == build_number

  UI.user_error!("Tag #{tag} build number does not match resolved build number #{build_number}")
end

def latest_build_number(api_key, version)
  testflight = latest_testflight_build_number(
    api_key: api_key,
    app_identifier: APP_IDENTIFIER,
    version: version,
    initial_build_number: 0
  ).to_i

  app_store = begin
    app_store_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      version: version,
      live: false
    ).to_i
  rescue => error
    UI.message("No App Store build number found for #{version}: #{error.message}")
    0
  end

  [testflight, app_store].max
end

def log_app_store_versions(api_key)
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**api_key)
  app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
  UI.user_error!("App Store Connect app not found: #{APP_IDENTIFIER}") unless app

  versions = app.get_app_store_versions(
    filter: { platform: Spaceship::ConnectAPI::Platform::IOS },
    includes: "build,appStoreVersionSubmission"
  )
  versions.sort_by { |version| Gem::Version.new(version.version_string) }.each do |version|
    build = version.respond_to?(:build) && version.build ? version.build.version : "none"
    UI.message(
      "App Store version #{version.version_string}: " \
      "appStoreState=#{version.app_store_state}, " \
      "appVersionState=#{version.app_version_state}, " \
      "build=#{build}, id=#{version.id}"
    )
  end

  edit_version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
  if edit_version
    UI.message("Editable App Store version: #{edit_version.version_string} (#{edit_version.app_store_state})")
  else
    UI.message("Editable App Store version: none")
  end
end

def cancel_pending_app_store_release!(api_key, version_string)
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**api_key)
  app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
  UI.user_error!("App Store Connect app not found: #{APP_IDENTIFIER}") unless app

  pending_version = app.get_pending_release_app_store_version(
    platform: Spaceship::ConnectAPI::Platform::IOS,
    includes: "appStoreVersionSubmission,build"
  )

  if pending_version.nil?
    UI.message("No pending App Store release found to cancel")
    return
  end

  UI.message(
    "Pending App Store release: #{pending_version.version_string} " \
    "(#{pending_version.app_store_state})"
  )
  UI.user_error!(
    "Pending release is #{pending_version.version_string}, expected #{version_string}"
  ) unless pending_version.version_string == version_string

  UI.user_error!("Pending release #{version_string} cannot be rejected") unless pending_version.can_reject?
  pending_version.reject!
  UI.success("Canceled pending App Store release #{version_string}")
end

def release_notes
  path = ENV["WHAT_TO_TEST_FILE"]
  path = File.expand_path(path, REPO_ROOT) if path && !path.start_with?("/")
  return File.read(path).strip if path && File.exist?(path)

  ENV.fetch("WHAT_TO_TEST", "").strip
end

platform :ios do
  desc "Run SwiftLint"
  lane :lint do
    sh("swiftlint lint --config #{File.join(REPO_ROOT, ".swiftlint.yml").shellescape}")
  end

  desc "Build the app for the iOS simulator"
  lane :build_debug do
    sh("xcodebuild build -project #{PROJECT.shellescape} -scheme #{SCHEME.shellescape} -destination #{DESTINATION.shellescape}")
  end

  desc "Run the full module test suite"
  lane :test do
    sh(File.join(REPO_ROOT, "run_tests.sh").shellescape + " -v")
  end

  desc "Generate App Store screenshots from deterministic UI-test fixtures"
  lane :screenshots do
    FileUtils.rm_rf(SCREENSHOT_OUTPUT_DIR)
    [
      { name: "light", dark_mode: false },
      { name: "dark", dark_mode: true }
    ].each do |appearance|
      output_dir = File.join(SCREENSHOT_OUTPUT_DIR, appearance[:name])
      FileUtils.rm_rf(SNAPSHOT_CACHE_DIR)
      snapshot(
        output_directory: output_dir,
        dark_mode: appearance[:dark_mode]
      )
      prepare_frameit_metadata(output_dir)
      frameit(path: output_dir)
    end
    write_screenshot_summary(SCREENSHOT_OUTPUT_DIR)
  end

  desc "Archive and export a signed App Store build"
  lane :archive do |options|
    build_number = options[:build_number]
    set_build_number(build_number) if build_number

    setup_ci if ENV["CI"]

    api_key = app_store_connect_key

    match(
      api_key: api_key,
      type: "appstore",
      readonly: true,
      app_identifier: [APP_IDENTIFIER, EXTENSION_IDENTIFIER],
      team_id: TEAM_ID
    )

    set_app_store_signing

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      export_options: {
        method: "app-store",
        uploadSymbols: true,
        signingStyle: "manual",
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}",
          EXTENSION_IDENTIFIER => "match AppStore #{EXTENSION_IDENTIFIER}"
        }
      },
      archive_path: "#{RELEASE_DIR}/Hackers.xcarchive",
      output_directory: RELEASE_DIR,
      output_name: "Hackers.ipa",
      result_bundle: true,
      result_bundle_path: "#{RELEASE_DIR}/Hackers-Release.xcresult",
      buildlog_path: LOG_DIR
    )
  end

  desc "Resolve the next build number, archive, and upload to TestFlight"
  lane :beta do |options|
    tag = options[:release_tag] || ENV["RELEASE_TAG"]
    validate_release_tag!(tag)
    require_release_tag_build_number!(tag)

    api_key = app_store_connect_key
    version = marketing_version
    source_build = source_build_number
    latest = latest_build_number(api_key, version)
    UI.user_error!("CURRENT_PROJECT_VERSION (#{source_build}) must be greater than latest available build (#{latest}) for #{version}") if source_build <= latest
    next_build = source_build
    validate_release_tag_build_number!(tag, next_build)

    notes = release_notes
    UI.user_error!("GitHub Release notes are required for TestFlight What to Test") if notes.empty?

    set_build_number(next_build)

    archive(build_number: next_build)

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      ipa: "#{RELEASE_DIR}/Hackers.ipa",
      changelog: notes,
      distribute_external: false,
      skip_waiting_for_build_processing: false
    )

    FileUtils.mkdir_p(RELEASE_DIR)
    File.write("#{RELEASE_DIR}/build-number.txt", "#{next_build}\n")
    UI.success("Uploaded Hackers #{version} (#{next_build}) to TestFlight")
  end

  desc "Submit a processed App Store Connect build for App Review"
  lane :submit_app_review do |options|
    tag = options[:release_tag] || ENV["RELEASE_TAG"]
    validate_release_tag!(tag)
    require_release_tag_build_number!(tag)
    tag_build_number = release_tag_parts(tag)[:build_number]

    api_key = app_store_connect_key
    log_app_store_versions(api_key)
    cancel_pending_app_store_release!(api_key, ENV["CANCEL_PENDING_VERSION"]) if ENV["CANCEL_PENDING_VERSION"].to_s != ""

    version = marketing_version
    notes = release_notes
    UI.user_error!("Release notes are required for App Store submission") if notes.empty?

    build_number = options[:build_number] || ENV["BUILD_NUMBER"]
    build_number = nil if build_number.to_s.strip.empty?
    if build_number
      build_number = build_number.to_i
      if build_number != tag_build_number
        UI.user_error!("Tag #{tag} includes build #{tag_build_number}, but requested build #{build_number} was provided")
      end
    else
      build_number = tag_build_number
    end
    UI.user_error!("No TestFlight build found for #{version}") if build_number.to_i <= 0

    upload_to_app_store(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: version,
      build_number: build_number.to_s,
      release_notes: { "en-GB" => notes },
      submit_for_review: true,
      automatic_release: false,
      skip_app_version_update: ENV["SKIP_APP_VERSION_UPDATE"] == "1",
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )

    UI.success("Submitted Hackers #{version} (#{build_number}) for App Review")
  end

  desc "Cancel a pending App Store review submission"
  lane :cancel_app_review do |options|
    version = options[:version] || ENV["CANCEL_PENDING_VERSION"]
    UI.user_error!("Version is required to cancel App Review") if version.to_s.strip.empty?

    api_key = app_store_connect_key
    cancel_pending_app_store_release!(api_key, version)
  end
end
